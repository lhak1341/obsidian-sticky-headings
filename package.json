{
  "name": "obsidian-sticky-headings",
  "version": "2.1.3",
  "description": "Display headings tree during editing and preview to indicate the current position.",
  "main": "main.js",
  "scripts": {
    "test": "bun test",
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "deploy": "bun run build && cp main.js manifest.json styles.css '/Users/lhak/Library/Mobile Documents/iCloud~md~obsidian/Documents/lhakZettel/.obsidian/plugins/another-sticky-headings/'",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "typesafe-i18n": "typesafe-i18n",
    "lint": "eslint ./",
    "pretty": "prettier --write \"./**/*.{mjs,cjs,ts,tsx,json,svelte}\"",
    "prepare": "husky",
    "postinstall": "rm -rf node_modules/eslint-plugin-obsidianmd/node_modules/eslint"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "markdown"
  ],
  "author": "Zhou Hua",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhouhua/obsidian-sticky-headings"
  },
  "bugs": {
    "url": "https://github.com/zhouhua/obsidian-sticky-headings/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@codemirror/view": "^6.32.0",
    "@eslint/js": "^10",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/eslint__js": "^9.14.0",
    "@types/lodash": "^4.17.7",
    "@types/node": "^26.1.0",
    "builtin-modules": "5.3.0",
    "esbuild": "0.28.1",
    "esbuild-svelte": "^0.9.5",
    "eslint": "10.6.0",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "husky": "^9.1.4",
    "obsidian": "latest",
    "obsidian-typings": "^6.19.0",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-preprocess": "^6.0.2",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "typesafe-i18n": "^5.26.2"
  },
  "overrides": {
    "eslint": "10.6.0"
  },
  "lint-staged": {
    "*.ts": "eslint --cache --fix",
    "*.{mjs,ts,json,svelte}": "prettier --write"
  }
}
